# Binance Futures Testnet Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_ACCOUNT_ID=your_account_id_here

# Binance Endpoints
BINANCE_REST_BASE=https://testnet.binancefuture.com
BINANCE_WS_BASE=wss://stream.binancefuture.com

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_POSITION_EVENTS_TOPIC=position-events
KAFKA_STATE_UPDATES_TOPIC=position-state-updates
KAFKA_CONSUMER_GROUP=tpe-position-tracker

# Aeron IPC Configuration
AERON_SUB_CHANNEL=aeron:ipc
AERON_SUB_STREAM_ID=10
AERON_PUB_CHANNEL=aeron:ipc
AERON_PUB_STREAM_ID=20
